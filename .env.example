# Docker Compose project name
COMPOSE_PROJECT_NAME=winemakingtodayyy

# PostgreSQL
POSTGRES_DB=vino_portal
POSTGRES_USER=vino
POSTGRES_PASSWORD=vino_secure_password
API_POSTGRES_DB=winetoday_v2

# Redis
REDIS_PASSWORD=vino_redis_password

# Site / public URLs
SITE_URL=http://localhost
NUXT_PUBLIC_SITE_URL=http://localhost
NUXT_PUBLIC_API_URL=http://localhost:4000/api
NUXT_PUBLIC_MEDIA_BASE_URL=http://localhost:4000
NUXT_PUBLIC_UPLOADS_URL=http://localhost:4000/uploads
NUXT_PUBLIC_EDITOR_URL=http://localhost:3000/account
MEDIA_URL=http://localhost/uploads

# API secrets
JWT_SECRET=change_me_jwt_secret_for_api
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_for_api
REVALIDATE_SECRET=change_me_revalidate_secret
COOKIE_DOMAIN=
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Migration sources (used only by db:migrate-v2)
SOURCE_API_DATABASE_URL=postgres://vino:vino_secure_password@postgres:5432/winetoday_api
SOURCE_STRAPI_DATABASE_URL=postgres://vino:vino_secure_password@postgres:5432/vino_portal

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Used for OAuth redirects (must match the public frontend URL)
FRONTEND_URL=${SITE_URL}

