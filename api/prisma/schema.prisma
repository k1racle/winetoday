generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  editor
  author
  member
}

enum ContentType {
  article
  news
  video
  gallery
  page
}

enum ContentStatus {
  draft
  in_review
  published
  rejected
}

enum ReactionType {
  like
  dislike
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  username      String?   @unique
  passwordHash  String?
  role          Role      @default(member)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  oauthAccounts       OAuthAccount[]
  memberProfile       MemberProfile?
  comments            Comment[]
  reactions           Reaction[]
  authorSubscriptions AuthorSubscription[]

  @@map("users")
}

model OAuthAccount {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  provider          String
  providerAccountId String   @map("provider_account_id")
  createdAt         DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model MemberProfile {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @db.Uuid
  displayName   String?  @map("display_name")
  accountType   String?  @map("account_type")
  authorId      String?  @unique @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  author Author? @relation(fields: [authorId], references: [id])

  @@map("member_profiles")
}

model Author {
  id                String           @id @default(uuid()) @db.Uuid
  name              String
  slug              String           @unique
  position          String?
  bio               String?
  memberProfileId   String?          @unique @db.Uuid
  avatarMediaId     String?          @db.Uuid
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  memberProfile     MemberProfile?
  avatarMedia       MediaAsset?      @relation("AuthorAvatar", fields: [avatarMediaId], references: [id])
  contentItems      ContentItem[]
  authorViewDaily   AuthorViewDaily[]
  subscriptions     AuthorSubscription[]

  @@map("authors")
}

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  parentId  String?   @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children Category[] @relation("CategoryParent")
  contentItems ContentItem[]

  @@map("categories")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contentItems ContentItem[]

  @@map("tags")
}

model MediaAsset {
  id          String   @id @default(uuid()) @db.Uuid
  path        String
  mime        String?
  width       Int?
  height      Int?
  altText     String?  @map("alt_text")
  sizeBytes   BigInt?  @map("size_bytes")
  createdAt   DateTime @default(now()) @map("created_at")

  coverContentItems        ContentItem[] @relation("CoverMedia")
  archiveCoverContentItems ContentItem[] @relation("ArchiveCoverMedia")
  siteSettingsLogo         SiteSettings? @relation("SiteSettingsLogo")
  siteHeaderLightLogo      SiteHeader?   @relation("SiteHeaderLightLogo")
  siteHeaderDarkLogo       SiteHeader?   @relation("SiteHeaderDarkLogo")
  siteSeoOgImage           SiteSeo?      @relation("SiteSeoOgImage")
  siteSeoTwitterImage      SiteSeo?      @relation("SiteSeoTwitterImage")
  authorAvatars            Author[]      @relation("AuthorAvatar")

  @@map("media_assets")
}

model ContentItem {
  id                    String        @id @default(uuid()) @db.Uuid
  type                  ContentType
  title                 String
  slug                  String
  excerpt               String?
  status                ContentStatus @default(draft)
  publishedAt           DateTime?     @map("published_at")
  publishedAtCustom     DateTime?     @map("published_at_custom")

  coverMediaId          String?       @db.Uuid
  archiveCoverMediaId   String?       @db.Uuid
  coverSource           String?       @map("cover_source")

  featured              Boolean       @default(false)
  pinned                Boolean       @default(false)
  homepageLead          Boolean       @default(false) @map("homepage_lead")
  homepageSpecialBlock  Boolean       @default(false) @map("homepage_special_block")
  materialLabel         String?       @map("material_label")
  readingTime           Int?          @map("reading_time")
  preview               Boolean       @default(false)

  contentBlocks         Json          @default("[]") @map("content_blocks")
  sources               Json?
  tastingNote           Json?         @map("tasting_note")
  videoUrl              String?       @map("video_url")
  duration              Int?
  seo                   Json?

  viewsTotal            Int           @default(0) @map("views_total")

  authorId              String?       @db.Uuid
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  submittedAt           DateTime?     @map("submitted_at")
  reviewedAt            DateTime?     @map("reviewed_at")
  reviewComment         String?       @map("review_comment")

  author      Author?    @relation(fields: [authorId], references: [id])
  coverMedia  MediaAsset? @relation("CoverMedia", fields: [coverMediaId], references: [id])
  archiveCoverMedia MediaAsset? @relation("ArchiveCoverMedia", fields: [archiveCoverMediaId], references: [id])
  categories  Category[]
  tags        Tag[]
  comments    Comment[]
  reactions   Reaction[]
  viewTotals  ContentViewTotal?
  viewDaily   ContentViewDaily[]
  viewEvents  ContentViewEvent[]

  @@unique([type, slug])
  @@unique([type, id])
  @@index([status, publishedAt])
  @@index([homepageLead])
  @@index([homepageSpecialBlock])
  @@map("content_items")
}

model Comment {
  id              String    @id @default(uuid()) @db.Uuid
  contentItemId   String    @db.Uuid
  userId          String?   @db.Uuid
  body            String
  status          String    @default("pending")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("comments")
}

model Reaction {
  id            String      @id @default(uuid()) @db.Uuid
  contentItemId String      @db.Uuid
  userId        String?     @db.Uuid
  viewerId      String?     @map("viewer_id")
  type          ReactionType
  createdAt     DateTime    @default(now()) @map("created_at")

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contentItemId, userId])
  @@unique([contentItemId, viewerId])
  @@map("reactions")
}

model ContentViewEvent {
  id            String      @id @default(uuid()) @db.Uuid
  contentType   ContentType @map("content_type")
  contentId     String      @db.Uuid
  slug          String
  authorId      String?     @db.Uuid
  viewerId      String      @map("viewer_id")
  viewedAt      DateTime    @default(now()) @map("viewed_at")
  ipHash        String?     @map("ip_hash")
  userAgent     String?     @map("user_agent")
  referrer      String?

  contentItem ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentType, contentId, viewerId])
  @@index([contentType, contentId])
  @@index([viewedAt])
  @@map("content_view_events")
}

model ContentViewTotal {
  contentType     ContentType @map("content_type")
  contentId       String      @db.Uuid
  viewsTotal      Int         @default(0) @map("views_total")
  uniqueViewers   Int         @default(0) @map("unique_viewers")
  lastViewedAt    DateTime?   @map("last_viewed_at")

  contentItem ContentItem @relation(fields: [contentType, contentId], references: [type, id], onDelete: Cascade)

  @@id([contentType, contentId])
  @@unique([contentId])
  @@map("content_view_totals")
}

model ContentViewDaily {
  date            DateTime    @db.Date
  contentType     ContentType @map("content_type")
  contentId       String      @db.Uuid
  authorId        String?     @db.Uuid
  views           Int         @default(0)
  uniqueViewers   Int         @default(0) @map("unique_viewers")

  contentItem ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@id([date, contentType, contentId])
  @@index([date])
  @@map("content_view_daily")
}

model AuthorSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  authorId  String   @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([userId, authorId])
  @@map("author_subscriptions")
}

model AuthorViewDaily {
  date            DateTime @db.Date
  authorId        String   @db.Uuid
  articleViews    Int      @default(0) @map("article_views")
  newsViews       Int      @default(0) @map("news_views")
  videoViews      Int      @default(0) @map("video_views")
  galleryViews    Int      @default(0) @map("gallery_views")
  totalViews      Int      @default(0) @map("total_views")

  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([date, authorId])
  @@map("author_view_daily")
}

model SiteSettings {
  id          String    @id @default(uuid()) @db.Uuid
  siteName    String?   @map("site_name")
  siteDescription String? @map("site_description")
  logoMediaId String?   @unique @db.Uuid
  typography  Json?
  socialLinks Json?     @map("social_links")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  logoMedia      MediaAsset? @relation("SiteSettingsLogo", fields: [logoMediaId], references: [id])

  @@map("site_settings")
}

model Homepage {
  id          String    @id @default(uuid()) @db.Uuid
  title       String?
  description String?
  infographicCards Json? @map("infographic_cards")
  blocks      Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("homepage")
}

model SiteHeader {
  id              String    @id @default(uuid()) @db.Uuid
  menu            Json?
  lightLogoMediaId String?  @unique @db.Uuid
  darkLogoMediaId  String?  @unique @db.Uuid
  stickyDesktop   Boolean   @default(false) @map("sticky_desktop")
  stickyTablet    Boolean   @default(false) @map("sticky_tablet")
  stickyMobile    Boolean   @default(false) @map("sticky_mobile")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  lightLogo MediaAsset? @relation("SiteHeaderLightLogo", fields: [lightLogoMediaId], references: [id])
  darkLogo  MediaAsset? @relation("SiteHeaderDarkLogo", fields: [darkLogoMediaId], references: [id])

  @@map("site_header")
}

model SiteFooter {
  id        String   @id @default(uuid()) @db.Uuid
  columns   Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_footer")
}

model SiteSeo {
  id          String    @id @default(uuid()) @db.Uuid
  defaultSeo  Json?     @map("default_seo")
  openGraphImageMediaId String? @unique @db.Uuid
  twitterImageMediaId   String? @unique @db.Uuid
  robotsEnabled         Boolean @default(true) @map("robots_enabled")
  robotsRules           Json?   @map("robots_rules")
  robotsHost            String? @map("robots_host")
  robotsAdditionalSitemaps String? @map("robots_additional_sitemaps")
  sitemapEnabled        Boolean @default(true) @map("sitemap_enabled")
  sitemapExcludePaths   String? @map("sitemap_exclude_paths")
  archiveSeo            Json?   @map("archive_seo")
  pageSeo               Json?   @map("page_seo")
  sitemapIncludeArticles Boolean @default(true) @map("sitemap_include_articles")
  sitemapIncludeNews    Boolean @default(true) @map("sitemap_include_news")
  sitemapIncludeVideos  Boolean @default(true) @map("sitemap_include_videos")
  sitemapIncludePages   Boolean @default(true) @map("sitemap_include_pages")
  sitemapIncludeGalleries Boolean @default(true) @map("sitemap_include_galleries")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  openGraphImage MediaAsset? @relation("SiteSeoOgImage", fields: [openGraphImageMediaId], references: [id])
  twitterImage   MediaAsset? @relation("SiteSeoTwitterImage", fields: [twitterImageMediaId], references: [id])

  @@map("site_seo")
}

model Sidebar {
  id        String    @id @default(uuid()) @db.Uuid
  title     String?
  path      String?
  paths     Json?
  links     Json?
  sections  Json?
  archiveBlocks Json? @map("archive_blocks")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("sidebars")
}

model CommunitySettings {
  id                String   @id @default(uuid()) @db.Uuid
  moderationEnabled Boolean  @default(true) @map("moderation_enabled")
  stopWords         String?  @map("stop_words")
  shareNetworks     Json?    @map("share_networks")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("community_settings")
}

model SocialAuthSettings {
  id        String   @id @default(uuid()) @db.Uuid
  providers Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("social_auth_settings")
}

model ArchiveSettings {
  id        String   @id @default(uuid()) @db.Uuid
  settings  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("archive_settings")
}

model StaticPage {
  id            String    @id @default(uuid()) @db.Uuid
  title         String
  slug          String    @unique
  contentBlocks Json      @default("[]") @map("content_blocks")
  seo           Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("static_pages")
}
