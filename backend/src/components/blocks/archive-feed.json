{
  "collectionName": "components_blocks_archive_feeds",
  "info": {
    "displayName": "Лента архива",
      "description": "Автозагружаемая лента статей, новостей, галерей или видео"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "contentType": {
      "type": "enumeration",
      "enum": ["articles", "news", "galleries", "videos"],
      "required": true,
      "default": "articles"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category"
    },
    "limit": {
      "type": "integer",
      "default": 12,
      "min": 1
    }
  }
}
