{
  "kind": "collectionType",
  "collectionName": "news_items",
  "info": {
    "singularName": "news",
    "pluralName": "news-entries",
    "displayName": "Новости",
    "description": "Новости и обновления индустрии"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "required": false
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "coverSource": {
      "type": "string"
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "blocks.hero",
        "blocks.archive-feed",
        "blocks.cta",
        "blocks.embed",
        "blocks.html-editor",
        "blocks.image-gallery",
        "blocks.image-slider",
        "blocks.link-grid",
        "blocks.rich-text",
        "blocks.quote",
        "blocks.image-highlight"
      ]
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "pinned": {
      "type": "boolean",
      "default": false
    },
    "homepageLead": {
      "type": "boolean",
      "default": false
    },
    "homepageSpecialBlock": {
      "type": "boolean",
      "default": false
    },
    "materialLabel": {
      "type": "enumeration",
      "enum": ["none", "exclusive", "video"],
      "default": "none",
      "required": false
    },
    "publishedAtCustom": {
      "type": "datetime"
    },
    "sources": {
      "type": "component",
      "repeatable": true,
      "component": "shared.source-link"
    },
    "sourceName": {
      "type": "string"
    },
    "sourceUrl": {
      "type": "string"
    },
    "memberProfile": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::member-profile.member-profile",
      "inversedBy": "newsItems"
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "news"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "news_items"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "news_items"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
