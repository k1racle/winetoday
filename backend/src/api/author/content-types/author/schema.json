{
  "kind": "collectionType",
  "collectionName": "authors",
  "info": {
    "singularName": "author",
    "pluralName": "authors",
    "displayName": "Авторы",
    "description": "Редакционные авторы и эксперты"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "position": {
      "type": "string"
    },
    "bio": {
      "type": "customField",
      "customField": "plugin::tiptap-editor.RichText",
      "options": {
        "preset": "full"
      }
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "email": {
      "type": "email"
    },
    "telegram": {
      "type": "string"
    },
    "website": {
      "type": "string"
    },
    "memberProfile": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::member-profile.member-profile",
      "mappedBy": "author"
    },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "author"
    },
    "news": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::news.news",
      "mappedBy": "author"
    },
    "videos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::video.video",
      "mappedBy": "author"
    }
  }
}
