{
  "kind": "singleType",
  "collectionName": "social_auth_settings",
  "info": {
    "singularName": "social-auth-setting",
    "pluralName": "social-auth-settings",
    "displayName": "Соцлогин",
    "description": "Настройки провайдеров social login для frontend-кабинета"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "googleEnabled": {
      "type": "boolean",
      "default": false
    },
    "googleClientId": {
      "type": "string"
    },
    "googleClientSecret": {
      "type": "string",
      "private": true
    },
    "googleScope": {
      "type": "string",
      "default": "email"
    },
    "vkEnabled": {
      "type": "boolean",
      "default": false
    },
    "vkClientId": {
      "type": "string"
    },
    "vkClientSecret": {
      "type": "string",
      "private": true
    },
    "vkScope": {
      "type": "string",
      "default": "email"
    },
    "yandexEnabled": {
      "type": "boolean",
      "default": false
    },
    "yandexClientId": {
      "type": "string"
    },
    "yandexClientSecret": {
      "type": "string",
      "private": true
    },
    "yandexScope": {
      "type": "string",
      "default": "login:email login:info"
    },
    "yandexAuthorizeUrl": {
      "type": "string",
      "default": "https://oauth.yandex.com/authorize"
    },
    "yandexAccessUrl": {
      "type": "string",
      "default": "https://oauth.yandex.com/token"
    }
  }
}
