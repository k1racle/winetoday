{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Страницы",
    "description": "Редакционные страницы сайта"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "text",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text"
    },
    "showInFooter": {
      "type": "boolean",
      "default": true
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "blocks.hero",
        "blocks.archive-feed",
        "blocks.cta",
        "blocks.embed",
        "blocks.html-editor",
        "blocks.image-gallery",
        "blocks.image-slider",
        "blocks.link-grid",
        "blocks.rich-text",
        "blocks.quote",
        "blocks.image-highlight"
      ]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
