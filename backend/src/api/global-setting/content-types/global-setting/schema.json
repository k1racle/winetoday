{
  "kind": "singleType",
  "collectionName": "global_settings",
  "info": {
    "singularName": "global-setting",
    "pluralName": "global-settings",
    "displayName": "Глобальные настройки",
    "description": "Настройки сайта, брендинга и навигации"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true,
      "default": "Wine Today"
    },
    "siteDescription": {
      "type": "text",
      "required": true,
      "default": "Современный русскоязычный портал о виноделии, регионах, событиях и людях индустрии."
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "tickerText": {
      "type": "text"
    },
     "typography": {
      "type": "component",
      "repeatable": false,
      "component": "shared.typography-settings"
    },
    "mobileBottomNav": {
      "type": "component",
      "repeatable": true,
      "component": "shared.navigation-link"
    },
    "socialLinks": {
      "type": "component",
      "repeatable": false,
      "component": "shared.social-links"
    }
  }
}
