{
  "kind": "collectionType",
  "collectionName": "galleries",
  "info": {
    "singularName": "gallery",
    "pluralName": "galleries",
    "displayName": "Галереи",
    "description": "Фотогалереи и визуальные подборки"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "required": true
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "archiveCover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "photos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "coverSource": {
      "type": "string"
    },
    "publishedAtCustom": {
      "type": "datetime"
    },
    "views": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "galleries"
    },
    "memberProfile": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::member-profile.member-profile",
      "inversedBy": "galleries"
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "galleries"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
