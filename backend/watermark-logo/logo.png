                        <div class="stage1">
                            
                            <div class="s1_right">
                                <div class="h_green s1_drop2">Our service allows<br />you to multiupload<br />files and folders</div>
                                <div class="h_green s1_drop3">Paste images or<br />text from clipboard<br />by pressing<br /><span>CTRL+V</span></div>
