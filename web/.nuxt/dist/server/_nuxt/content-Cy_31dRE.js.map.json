{"file":"content-Cy_31dRE.js","mappings":";;;;;;;;;;;;;;;;;;;;;;AAakC,YAAA;AACH,WAAA;AAE/B,UAAM,YAAY,IAAgB,EAAE;AACpC,UAAM,QAAQ,IAAI,CAAC;AACnB,UAAM,SAAS,IAAW,EAAE;AAC5B,UAAM,UAAU,IAAI,KAAK;AACzB,UAAM,QAAQ,IAAI,EAAE;AAEpB,UAAM,aAAa,IAAI,EAAE;AACzB,UAAM,eAAe,IAAI,EAAE;AAC3B,UAAM,SAAS,IAAI,EAAE;AAErB,UAAM,cAAc;AAAA,MAClB,EAAE,OAAO,IAAI,OAAO,WAAA;AAAA,MACpB,EAAE,OAAO,WAAW,OAAO,SAAA;AAAA,MAC3B,EAAE,OAAO,QAAQ,OAAO,UAAA;AAAA,MACxB,EAAE,OAAO,SAAS,OAAO,QAAA;AAAA,MACzB,EAAE,OAAO,WAAW,OAAO,UAAA;AAAA,IAAU;AAGvC,UAAM,gBAAgB;AAAA,MACpB,EAAE,OAAO,IAAI,OAAO,cAAA;AAAA,MACpB,EAAE,OAAO,SAAS,OAAO,WAAA;AAAA,MACzB,EAAE,OAAO,aAAa,OAAO,cAAA;AAAA,MAC7B,EAAE,OAAO,aAAa,OAAO,eAAA;AAAA,MAC7B,EAAE,OAAO,YAAY,OAAO,YAAA;AAAA,IAAY;AAG1C,UAAM,aAAqC;AAAA,MACzC,SAAS;AAAA,MACT,MAAM;AAAA,MACN,OAAO;AAAA,MACP,SAAS;AAAA,IAAA;AAGX,UAAM,eAAuC;AAAA,MAC3C,OAAO;AAAA,MACP,WAAW;AAAA,MACX,WAAW;AAAA,MACX,UAAU;AAAA,IAAA;AAGZ,UAAM,eAAuC;AAAA,MAC3C,OAAO;AAAA,MACP,WAAW;AAAA,MACX,WAAW;AAAA,MACX,UAAU;AAAA,IAAA;AAsBZ,aAAS,aAAa,MAAc;AAClC,aAAO,OAAO,MAAM,KAAK,CAAC,MAAM,EAAE,SAAS,IAAI,GAAG,QAAQ,QAAQ;AAAA,IACpE;AAEA,aAAS,WAAW,MAAsB;AACxC,UAAI,CAAC,KAAM,QAAO;AAClB,aAAO,IAAI,KAAK,IAAI,EAAE,mBAAmB,OAAO;AAAA,IAClD;;;;AAYO,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,iCAA6B,MAAA,CAAA,CAAA,6RAAA;;QAM5B,IAAG;AAAA,QAAW,OAAM;AAAA,MAAA;yBAA9B,CAAgG,GAAAC,QAAAC,UAAA,aAAA;;;;;8BAA5B,mBAAiB;AAAA,YAAA;AAAA;;;;AAE1E,YAAAC,mBAAA,sBAAA,EAAA,OAAM,UAAM,MAAA,OAAA,CAAA;;oBAIF,YAAY,OAAO,CAAA,MAAK,EAAE,KAAK,GAAA,CAAtC,QAAG;oJAC4BC,eAAA,IAAI,KAAK,oEAClB,aAAa,IAAI,KAAK,CAAA;;;AAS9BC,oBAAA,cAAP,QAAG;sCAAmC,SAAO,IAAI,KAAK,wDADtDC,MAAA,UAAA,CAAU,oBAAVA,MAAA,UAAA,GAC6C,IAAI,KAAK,kBADtDA,MAAA,UAAA,GAC6C,IAAI,KAAK,CAAA,IAAA,cAAA,MAAKF,eAAA,IAAI,KAAK;;;AAM7DC,oBAAA,gBAAP,QAAG;sCAAqC,SAAO,IAAI,KAAK,wDADxDC,MAAA,YAAA,CAAY,oBAAZA,MAAA,YAAA,GAC+C,IAAI,KAAK,kBADxDA,MAAA,YAAA,GAC+C,IAAI,KAAK,CAAA,IAAA,cAAA,MAAKF,eAAA,IAAI,KAAK;;mMAKvEE,MAAA,MAAA,CAAM,CAAA,8SAAA;UAMjBA,MAAA,OAAA,GAAO;;;;;UACPA,MAAA,KAAA,GAAK;qFAAuCA,MAAA,KAAA,CAAK,CAAA,MAAA;AAAA;;;gGAELA,MAAA,KAAA,CAAK,CAAA,MAAA;WAE9CA,MAAA,OAAA,KAAWA,MAAA,SAAA,EAAU,QAAM;;AAajBD,sBAAAC,MAAA,SAAA,IAAL,MAAC;qOAGqC,aAAa,EAAE,MAAM,KAAA,eAAA,sBAAA,CAAA,8BAC7DF,eAAA,aAAa,EAAE,MAAM,KAAK,EAAE,MAAM,kFAGYA,eAAA,WAAW,EAAE,IAAI,KAAK,EAAE,IAAI;;YAEpE,IAAE,IAAM,EAAE,kCAAkC,EAAE,SAAI,SAAA,SAAuB,EAAE,SAAI,UAAA,WAAA,SAAA,IAAuC,EAAE,IAAI;AAAA,YAAI,OAAM;AAAA,YAAwC,QAAO;AAAA,UAAA;6BAAhM,CAEW,GAAAH,QAAAC,UAAA,aAAA;;AADND,uBAAA,GAAAG,eAAA,EAAE,KAAK,CAAA,EAAA;AAAA;;kBAAPG,gBAAAC,gBAAA,EAAE,KAAK,GAAA,CAAA;AAAA,gBAAA;AAAA;;;;yGAGuC,EAAE,QAAQ,QAAI,GAAA,2EACdJ,eAAA,EAAE,cAAU,CAAA,0FACZ,WAAW,EAAE,SAAS,CAAA;;;;;;WAMzEE,MAAA,OAAA,KAAO,CAAKA,MAAA,SAAA,EAAU,QAAM;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_push","_parent","_ssrRenderComponent","_ssrInterpolate","_ssrRenderList","_unref","_createTextVNode","_toDisplayString"],"sources":["../../../../pages/account/admin/content.vue"],"sourcesContent":["<script setup lang=\"ts\">\ninterface Material {\n  id: string;\n  type: string;\n  title: string;\n  slug: string;\n  status: string;\n  updatedAt: string;\n  publishedAt?: string | null;\n  viewsTotal: number;\n  author?: { name: string } | null;\n}\n\nconst { user, isAuthenticated } = useAuth();\nconst { getEditorMaterials } = useApi();\n\nconst materials = ref<Material[]>([]);\nconst total = ref(0);\nconst counts = ref<any[]>([]);\nconst loading = ref(false);\nconst error = ref('');\n\nconst typeFilter = ref('');\nconst statusFilter = ref('');\nconst search = ref('');\n\nconst typeOptions = [\n  { value: '', label: 'Все типы' },\n  { value: 'article', label: 'Статьи' },\n  { value: 'news', label: 'Новости' },\n  { value: 'video', label: 'Видео' },\n  { value: 'gallery', label: 'Галереи' },\n];\n\nconst statusOptions = [\n  { value: '', label: 'Все статусы' },\n  { value: 'draft', label: 'Черновик' },\n  { value: 'in_review', label: 'На проверке' },\n  { value: 'published', label: 'Опубликовано' },\n  { value: 'rejected', label: 'Отклонено' },\n];\n\nconst typeLabels: Record<string, string> = {\n  article: 'Статья',\n  news: 'Новость',\n  video: 'Видео',\n  gallery: 'Галерея',\n};\n\nconst statusLabels: Record<string, string> = {\n  draft: 'Черновик',\n  in_review: 'На проверке',\n  published: 'Опубликовано',\n  rejected: 'Отклонено',\n};\n\nconst statusColors: Record<string, string> = {\n  draft: 'bg-orange-500',\n  in_review: 'bg-yellow-500',\n  published: 'bg-accent',\n  rejected: 'bg-red-600',\n};\n\nasync function fetchMaterials() {\n  loading.value = true;\n  error.value = '';\n  try {\n    const query: Record<string, string> = {};\n    if (typeFilter.value) query.type = typeFilter.value;\n    if (statusFilter.value) query.status = statusFilter.value;\n    if (search.value.trim()) query.search = search.value.trim();\n    const res: any = await getEditorMaterials(query);\n    materials.value = Array.isArray(res?.items) ? res.items : [];\n    total.value = res?.total || 0;\n    counts.value = Array.isArray(res?.counts) ? res.counts : [];\n  } catch (err: any) {\n    error.value = err?.data?.message || err?.message || 'Ошибка загрузки материалов';\n  } finally {\n    loading.value = false;\n  }\n}\n\nfunction countForType(type: string) {\n  return counts.value.find((c) => c.type === type)?._count?.type || 0;\n}\n\nfunction formatDate(date?: string | null) {\n  if (!date) return '—';\n  return new Date(date).toLocaleDateString('ru-RU');\n}\n\nonMounted(() => {\n  if (!isAuthenticated.value || user.value?.role !== 'admin') {\n    navigateTo('/account');\n    return;\n  }\n  fetchMaterials();\n});\n</script>\n\n<template>\n  <div class=\"mx-auto max-w-6xl px-4 py-8\">\n    <div class=\"mb-6 border-b border-foreground/10 pb-4\">\n      <p class=\"text-xs font-medium uppercase tracking-wider text-foreground/50\">Администрирование</p>\n      <h1 class=\"mt-2 font-heading text-2xl font-bold\">Материалы</h1>\n    </div>\n\n    <NuxtLink to=\"/account\" class=\"text-sm text-accent hover:underline\">← Назад в кабинет</NuxtLink>\n\n    <AdminTabs class=\"mt-6\" />\n\n    <!-- Counts -->\n    <div class=\"mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4\">\n      <div v-for=\"opt in typeOptions.filter(o => o.value)\" :key=\"opt.value\" class=\"border border-foreground/10 bg-foreground/5 p-3\">\n        <p class=\"text-xs text-foreground/60\">{{ opt.label }}</p>\n        <p class=\"text-xl font-bold\">{{ countForType(opt.value) }}</p>\n      </div>\n    </div>\n\n    <!-- Filters -->\n    <div class=\"mt-6 flex flex-wrap items-end gap-3\">\n      <div>\n        <label class=\"mb-1 block text-xs font-medium text-foreground/70\">Тип</label>\n        <select v-model=\"typeFilter\" class=\"border border-foreground/10 bg-foreground/5 px-3 py-2 text-sm outline-none focus:border-accent\" @change=\"fetchMaterials\">\n          <option v-for=\"opt in typeOptions\" :key=\"opt.value\" :value=\"opt.value\">{{ opt.label }}</option>\n        </select>\n      </div>\n      <div>\n        <label class=\"mb-1 block text-xs font-medium text-foreground/70\">Статус</label>\n        <select v-model=\"statusFilter\" class=\"border border-foreground/10 bg-foreground/5 px-3 py-2 text-sm outline-none focus:border-accent\" @change=\"fetchMaterials\">\n          <option v-for=\"opt in statusOptions\" :key=\"opt.value\" :value=\"opt.value\">{{ opt.label }}</option>\n        </select>\n      </div>\n      <div>\n        <label class=\"mb-1 block text-xs font-medium text-foreground/70\">Поиск по заголовку</label>\n        <input v-model=\"search\" type=\"text\" class=\"border border-foreground/10 bg-foreground/5 px-3 py-2 text-sm outline-none focus:border-accent\" placeholder=\"Введите заголовок...\" @keyup.enter=\"fetchMaterials\">\n      </div>\n      <button class=\"btn-primary\" @click=\"fetchMaterials\">Найти</button>\n      <button class=\"btn-secondary\" @click=\"typeFilter = ''; statusFilter = ''; search = ''; fetchMaterials()\">Сбросить</button>\n    </div>\n\n    <p v-if=\"loading\" class=\"mt-6 text-sm text-foreground/60\">Загрузка...</p>\n    <p v-if=\"error\" class=\"mt-6 text-sm text-red-600\">{{ error }}</p>\n\n    <p class=\"mt-4 text-xs text-foreground/60\">Всего: {{ total }}</p>\n\n    <div v-if=\"!loading && materials.length\" class=\"mt-4 overflow-x-auto\">\n      <table class=\"w-full border-collapse border border-foreground/10 text-sm\">\n        <thead class=\"bg-foreground/10\">\n          <tr>\n            <th class=\"border border-foreground/10 px-4 py-2 text-left\">Статус</th>\n            <th class=\"border border-foreground/10 px-4 py-2 text-left\">Тип</th>\n            <th class=\"border border-foreground/10 px-4 py-2 text-left\">Заголовок</th>\n            <th class=\"border border-foreground/10 px-4 py-2 text-left\">Автор</th>\n            <th class=\"border border-foreground/10 px-4 py-2 text-left\">Просмотры</th>\n            <th class=\"border border-foreground/10 px-4 py-2 text-left\">Обновлено</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr v-for=\"m in materials\" :key=\"m.id\" class=\"bg-foreground/5\">\n            <td class=\"border border-foreground/10 px-4 py-2\">\n              <span class=\"inline-flex items-center gap-1.5 text-xs\">\n                <span class=\"h-2 w-2 rounded-full\" :class=\"statusColors[m.status] || 'bg-gray-400'\" />\n                {{ statusLabels[m.status] || m.status }}\n              </span>\n            </td>\n            <td class=\"border border-foreground/10 px-4 py-2\">{{ typeLabels[m.type] || m.type }}</td>\n            <td class=\"border border-foreground/10 px-4 py-2\">\n              <NuxtLink :to=\"`/${m.type === 'article' ? 'articles' : m.type === 'news' ? 'news' : m.type === 'video' ? 'videos' : 'gallery'}/${m.slug}`\" class=\"hover:text-foreground hover:underline\" target=\"_blank\">\n                {{ m.title }}\n              </NuxtLink>\n            </td>\n            <td class=\"border border-foreground/10 px-4 py-2\">{{ m.author?.name || '—' }}</td>\n            <td class=\"border border-foreground/10 px-4 py-2\">{{ m.viewsTotal || 0 }}</td>\n            <td class=\"border border-foreground/10 px-4 py-2\">{{ formatDate(m.updatedAt) }}</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n\n    <p v-if=\"!loading && !materials.length\" class=\"mt-6 text-sm text-foreground/60\">Материалы не найдены</p>\n  </div>\n</template>\n\n<style scoped>\n.btn-primary {\n  @apply inline-flex items-center gap-1.5 bg-accent px-4 py-2 text-sm font-medium text-white transition hover:bg-accent/90 disabled:opacity-50;\n}\n.btn-secondary {\n  @apply inline-flex items-center gap-1.5 border border-foreground/10 bg-foreground/5 px-4 py-2 text-sm font-medium text-foreground transition hover:bg-foreground/10 disabled:opacity-50;\n}\n</style>\n"],"version":3}