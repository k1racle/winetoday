IAAI;AACf,gBAAI,MAAM,UAAU,EAAG;AAAA,UACzB;AAAA,QACF;AAAA,MACF;AACA,aAAO,MAAM,MAAM,GAAG,CAAC;AAAA,IACzB,CAAC;AAED,aAAS,WAAW,MAAsB;AACxC,UAAI,CAAC,KAAM,QAAO;AAClB,aAAO,IAAI,KAAK,IAAI,EAAE,mBAAmB,SAAS,EAAE,MAAM,WAAW,QAAQ,WAAW;AAAA,IAC1F;;;;;;;AAIO,YAAA,OAAAH,eAAAC,WAAA,EAAA,OAAM,iCAA6B,MAAA,CAAA,CAAA,mLAAA;;QAKtB,IAAG;AAAA,QAAI,OAAM;AAAA,MAAA;yBAAvB,CAAiE,GAAAG,QAAAC,UAAA,aAAA;;;;;8BAAlB,SAAO;AAAA,YAAA;AAAA;;;;;;QAE3C,IAAI,QAAA;AAAA,QAAW,OAAM;AAAA,MAAA;yBAAhC,CAAkF,GAAAD,QAAAC,UAAA,aAAA;;qCAAvB,QAAA,SAAS,CAAA,EAAA;AAAA;;8CAAT,QAAA,SAAS,GAAA,CAAA;AAAA,YAAA;AAAA;;;;kEAKjEH,eAAA,WAAW,QAAA,KAAK,eAAe,QAAA,KAAK,SAAS,CAAA,gFAK7CA,eAAA,QAAA,KAAK,KAAK;UAIDI,MAAA,QAAA,GAAQ;;;UAEjB,KAAKA,MAAA,QAAA;AAAA,UACL,KAAK,aAAK,YAAY,WAAW,QAAA,KAAK;AAAA,UACvC,OAAM;AAAA,QAAA;AAEU,YAAA,QAAA,KAAK,aAAW;AACnB,gBAAA,uGAAAJ,eAAA,QAAA,KAAK,WAAW,CAAA,eAAA;AAAA;;;;;;;;UAMV,QAAA,KAAK,eAAe,QAAM;;UAAG,QAAQ,QAAA,KAAK;AAAA,UAAgB,MAAM,QAAA;AAAA,QAAA;MACvE,WAAA,QAAA,KAAK,SAAO;AACrB,cAAA,iDAAAA,eAAA,QAAA,KAAK,OAAO,CAAA,MAAA;AAAA;;;;AAiCR,UAAAI,MAAA,YAAA,EAAa,QAAM;;AAITC,sBAAAD,MAAA,YAAA,IAAR,SAAI;;YACV,KAAK,KAAK;AAAA,YACV;AAAA,YACD,gBAAa;AAAA,YACb,SAAQ;AAAA,YACR,OAAM;AAAA,UAAA;;;;;;8WAUGA,MAAA,WAAA,CAAW,4GAOwBJ,eAAAI,MAAA,WAAA,EAAY,MAAM;;QAahD,QAAQA,MAAA,cAAA,KAAc,CAAA;AAAA,MAAA;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrInterpolate","_withAsyncContext","_push","_parent","_unref","_ssrRenderList"],"sources":["../../../../components/ContentBlocks.vue","../../../../components/ContentDetail.vue"],"sourcesContent":["<script setup lang=\"ts\">\nimport type { ContentItem } from '~/types/content';\n\nconst props = defineProps<{\n  blocks: any[];\n  item: ContentItem;\n}>();\n\nfunction getEmbedUrl(url?: string) {\n  if (!url) return '';\n  const youtubeMatch = url.match(/(?:youtube\\.com\\/watch\\?v=|youtu\\.be\\/)([\\w-]+)/);\n  if (youtubeMatch) return `https://www.youtube.com/embed/${youtubeMatch[1]}`;\n  return url;\n}\n</script>\n\n<template>\n  <div class=\"space-y-6\">\n    <template v-for=\"block in props.blocks\" :key=\"block.id\">\n      <div\n        v-if=\"block.type === 'rich-text' || block.type === 'html-editor'\"\n        class=\"prose prose-lg max-w-none text-foreground\"\n        v-html=\"block.content\"\n      />\n\n      <figure v-else-if=\"block.type === 'image-highlight'\" class=\"my-6\">\n        <NuxtImg\n          v-if=\"block.imageId\"\n          :src=\"`/api/media/${block.imageId}`\"\n          :alt=\"block.caption || ''\"\n          class=\"w-full\"\n        />\n        <figcaption v-if=\"block.caption || block.credit\" class=\"mt-2 text-sm text-foreground/60\">\n          {{ block.caption }}\n          <span v-if=\"block.credit\"> / {{ block.credit }}</span>\n        </figcaption>\n      </figure>\n\n      <blockquote\n        v-else-if=\"block.type === 'quote'\"\n        class=\"border-l-4 border-accent bg-accent/5 p-6 italic\"\n      >\n        <p class=\"text-lg\">{{ block.text }}</p>\n        <footer v-if=\"block.author\" class=\"mt-3 text-sm font-medium not-italic\">\n          {{ block.author }}<span v-if=\"block.role\">, {{ block.role }}</span>\n        </footer>\n      </blockquote>\n\n      <div\n        v-else-if=\"block.type === 'embed' && block.html\"\n        class=\"my-6\"\n        v-html=\"block.html\"\n      />\n\n      <div v-else-if=\"block.type === 'video-player'\" class=\"my-6 aspect-video w-full bg-black\">\n        <iframe\n          v-if=\"getEmbedUrl(block.videoUrl || props.item.videoUrl)\"\n          :src=\"getEmbedUrl(block.videoUrl || props.item.videoUrl)\"\n          class=\"h-full w-full\"\n          frameborder=\"0\"\n          allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\"\n          allowfullscreen\n        />\n      </div>\n    </template>\n  </div>\n</template>\n","<script setup lang=\"ts\">\nimport type { ContentItem } from '~/types/content';\n\nconst props = defineProps<{\n  item: ContentItem;\n  typeLabel: string;\n  typeRoute: string;\n}>();\n\nconst { getLatestByCategory } = useApi();\nconst { data: categoryGroups } = await useAsyncData('latest-by-category', () =>\n  getLatestByCategory(5).catch(() => []),\n);\n\nconst meta = computed(() => useContentMeta(props.item));\nconst coverSrc = computed(() => useMediaUrl(props.item.coverMedia?.path));\nconst commentText = ref('');\n\nconst relatedItems = computed(() => {\n  const groups = categoryGroups.value || [];\n  if (!groups.length) return [];\n  const currentId = props.item.id;\n  const categoryId = props.item.categories?.[0]?.id;\n  let items: ContentItem[] = [];\n  if (categoryId) {\n    const group = groups.find((g) => g.category.id === categoryId);\n    if (group) items = group.items.filter((i) => i.id !== currentId);\n  }\n  if (items.length < 3) {\n    const existingIds = new Set(items.map((i) => i.id));\n    const allItems = groups.flatMap((g) => g.items).filter((i) => i.id !== currentId);\n    for (const item of allItems) {\n      if (!existingIds.has(item.id)) {\n        items.push(item);\n        if (items.length >= 3) break;\n      }\n    }\n  }\n  return items.slice(0, 3);\n});\n\nfunction formatTime(date?: string | null) {\n  if (!date) return '';\n  return new Date(date).toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });\n}\n</script>\n\n<template>\n  <div class=\"mx-auto max-w-7xl px-4 py-8\">\n    <div class=\"grid gap-8 lg:grid-cols-4\">\n      <article class=\"lg:col-span-3\">\n        <!-- Breadcrumbs -->\n        <nav class=\"mb-4 flex items-center gap-2 text-xs font-medium uppercase tracking-wider text-foreground/50\">\n          <NuxtLink to=\"/\" class=\"hover:text-foreground\">Главная</NuxtLink>\n          <span>/</span>\n          <NuxtLink :to=\"typeRoute\" class=\"hover:text-foreground\">{{ typeLabel }}</NuxtLink>\n        </nav>\n\n        <!-- Time -->\n        <div class=\"mb-3 text-sm text-foreground/50\">\n          {{ formatTime(item.publishedAt || item.createdAt) }}\n        </div>\n\n        <!-- Title -->\n        <h1 class=\"font-heading text-3xl font-bold leading-tight md:text-4xl\">\n          {{ item.title }}\n        </h1>\n\n        <!-- Cover image -->\n        <figure v-if=\"coverSrc\" class=\"mt-6\">\n          <NuxtImg\n            :src=\"coverSrc\"\n            :alt=\"item.coverMedia?.altText || item.title\"\n            class=\"aspect-video w-full object-cover\"\n          />\n          <figcaption v-if=\"item.coverSource\" class=\"mt-2 text-xs font-medium uppercase tracking-wider text-foreground/50\">\n            Источник: {{ item.coverSource }}\n          </figcaption>\n        </figure>\n\n        <!-- Content -->\n        <div class=\"mt-8\">\n          <ContentBlocks v-if=\"item.contentBlocks?.length\" :blocks=\"item.contentBlocks\" :item=\"item\" />\n          <p v-else-if=\"item.excerpt\" class=\"text-lg leading-relaxed opacity-80\">\n            {{ item.excerpt }}\n          </p>\n        </div>\n\n        <!-- Reactions -->\n        <div class=\"mt-10 flex items-center justify-between border-t border-foreground/10 pt-4\">\n          <div class=\"flex items-center gap-4\">\n            <button type=\"button\" class=\"flex items-center gap-1.5 text-foreground/60 transition hover:text-foreground\" aria-label=\"Нравится\">\n              <svg class=\"h-5 w-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M6.633 10.25c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 0 1 2.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 0 0 .322-1.672V2.75a.75.75 0 0 1 .75-.75 2.25 2.25 0 0 1 2.25 2.25c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 0 1-2.649 7.521c-.388.482-.987.729-1.605.729H13.48c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 0 0-1.423-.23H5.904m10.598-9.75H14.25M5.904 18.5c.083.205.173.405.27.602.197.4-.078.898-.523.898h-.908c-.889 0-1.713-.518-1.972-1.368a12.784 12.784 0 0 1-.52-3.369c0-1.242.2-2.489.58-3.628M5.904 18.5H10.5m-4.596 0v-9.75m0 9.75v2.25\" />\n              </svg>\n            </button>\n            <button type=\"button\" class=\"flex items-center gap-1.5 text-foreground/60 transition hover:text-foreground\" aria-label=\"Комментарии\">\n              <svg class=\"h-5 w-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M2.25 12.76c0 1.6 1.123 2.994 2.707 3.227 1.068.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 0 1 1.037-.443 48.282 48.282 0 0 0 5.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z\" />\n              </svg>\n            </button>\n          </div>\n          <div class=\"flex items-center gap-4\">\n            <button type=\"button\" class=\"flex items-center gap-1.5 text-foreground/60 transition hover:text-foreground\" aria-label=\"Не нравится\">\n              <svg class=\"h-5 w-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M7.498 15.25H4.372c-1.026 0-1.945-.694-2.054-1.715a12.137 12.137 0 0 1-.068-1.285c0-2.848.992-5.464 2.649-7.521C5.287 4.247 5.886 4 6.504 4h4.016a6 6 0 0 1 1.423.23l3.114 1.04a4.5 4.5 0 0 0 1.423.23h1.294M7.498 15.25c.618 0 .991.272 1.067.844.064.455.27.867.585 1.18.317.313.728.515 1.178.515M7.498 15.25H13.5m-6 0v2.25m0-2.25h6m-6 0V5.75m6 9.75v2.25m0-2.25h-6m6 0V5.75\" />\n              </svg>\n            </button>\n            <button type=\"button\" class=\"flex items-center gap-1.5 text-foreground/60 transition hover:text-foreground\" aria-label=\"Поделиться\">\n              <svg class=\"h-5 w-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M7.217 10.907a2.25 2.25 0 1 0 0 2.186m9.566-1.43a2.25 2.25 0 1 0 0-2.186m-9.566 1.43a2.25 2.25 0 0 0 1.992-1.992m7.574-3.818a2.25 2.25 0 0 0 1.992 1.992M16.5 7.5a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z\" />\n              </svg>\n            </button>\n          </div>\n        </div>\n\n        <!-- Related articles -->\n        <div v-if=\"relatedItems.length\" class=\"mt-10\">\n          <h2 class=\"mb-4 font-heading text-xl font-bold\">Читайте также</h2>\n          <div class=\"grid gap-4 sm:grid-cols-2 lg:grid-cols-3\">\n            <ArticleCard\n              v-for=\"item in relatedItems\"\n              :key=\"item.id\"\n              :item=\"item\"\n              image-aspect=\"video\"\n              variant=\"compact\"\n              class=\"h-[320px]\"\n            />\n          </div>\n        </div>\n\n        <!-- Comments -->\n        <div class=\"mt-10\">\n          <h2 class=\"mb-4 font-heading text-xl font-bold\">Комментарии</h2>\n          <div class=\"border border-foreground/10 bg-card p-4\">\n            <textarea\n              v-model=\"commentText\"\n              rows=\"4\"\n              placeholder=\"Поделитесь мнением о материале\"\n              maxlength=\"3000\"\n              class=\"w-full resize-none border border-foreground/10 bg-card p-3 text-sm outline-none transition focus:border-accent\"\n            />\n            <div class=\"mt-3 flex items-center justify-between\">\n              <span class=\"text-xs text-foreground/50\">{{ commentText.length }} / 3000</span>\n              <button\n                type=\"button\"\n                class=\"rounded bg-accent px-4 py-2 text-sm font-medium text-white transition hover:bg-accent/90\"\n              >\n                Отправить\n              </button>\n            </div>\n          </div>\n        </div>\n      </article>\n\n      <aside class=\"lg:col-span-1\">\n        <SidebarByCategory :groups=\"categoryGroups || []\" />\n      </aside>\n    </div>\n  </div>\n</template>\n"],"version":3}