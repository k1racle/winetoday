{"file":"AuthorByline-HqjiVauP.js","mappings":";;;;;;;;;;;;;;;;AAGA,UAAM,QAAQ;AASc,YAAA;AACgD,WAAA;AAC9D,aAAA;AAEd,UAAM,aAAa,SAAS,MAAM,WAAW,MAAM,OAAO,IAAI,EAAE;AAChE,UAAM,YAAY,SAAS,MAAM,YAAY,MAAM,OAAO,aAAa,IAAI,CAAC;AAC5E,UAAM,WAAW,SAAS,MAAM;AAC9B,YAAM,OAAO,MAAM,OAAO,QAAQ;AAClC,aAAO,KAAK,OAAO,OAAO,CAAC,EAAE,iBAAiB;AAAA,IAChD,CAAC;AAED,UAAM,aAAa,IAAI,KAAK;AAC5B,UAAM,UAAU,IAAI,KAAK;;;;AAyClB,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,6BAAyB,MAAA,CAAA,CAAA,GAAA;;QACvB,IAAIC,MAAA,UAAA;AAAA,QAAY,OAAM;AAAA,MAAA;yBAAjC,CAcW,GAAAC,QAAAC,UAAA,aAAA;;gBAbEF,MAAA,SAAA,GAAS;;;gBAEf,KAAKA,MAAA,SAAA;AAAA,gBACL,KAAK,QAAA,OAAO;AAAA,gBACb,OAAM;AAAA,cAAA;;;2KAOLA,MAAA,QAAA,CAAQ;;;;cAXFA,MAAA,SAAA,kBAAXG,YAMM,OAAA;AAAA;gBANgB,OAAM;AAAA,cAAA;gBAC1BC,YAIE,oBAAA;AAAA,kBAHC,KAAKJ,MAAA,SAAA;AAAA,kBACL,KAAK,QAAA,OAAO;AAAA,kBACb,OAAM;AAAA,gBAAA;kCAGVG,YAKM,OAAA;AAAA;gBAHJ,OAAM;AAAA,cAAA,mBAEHH,MAAA,QAAA,CAAQ,GAAA,CAAA;AAAA,YAAA;AAAA;;;;;;QAKF,IAAIA,MAAA,UAAA;AAAA,QAAY,OAAM;AAAA,MAAA;yBAAjC,CAEW,GAAAC,QAAAC,UAAA,aAAA;;AADND,mBAAA,GAAAI,eAAA,QAAA,OAAO,IAAI,CAAA,EAAA;AAAA;;cAAXC,gBAAAC,gBAAA,QAAA,OAAO,IAAI,GAAA,CAAA;AAAA,YAAA;AAAA;;;;WAGP,QAAA,eAAa;4DAETP,MAAA,OAAA,CAAO,IAAA,cAAA,qGAIfA,MAAA,UAAA,IAAU,iBAAA,aAAA;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_unref","_push","_parent","_createBlock","_createVNode","_ssrInterpolate","_createTextVNode","_toDisplayString"],"sources":["../../../../../../../components/AuthorByline.vue"],"sourcesContent":["<script setup lang=\"ts\">\nimport type { Author } from '~/types/content';\n\nconst props = defineProps<{\n  author: Author;\n  hideSubscribe?: boolean;\n}>();\n\nconst emit = defineEmits<{\n  (e: 'change', subscribed: boolean): void;\n}>();\n\nconst { isAuthenticated } = useAuth();\nconst { getAuthorSubscription, subscribeToAuthor, unsubscribeFromAuthor } = useApi();\nconst route = useRoute();\n\nconst authorLink = computed(() => `/author/${props.author.slug}`);\nconst avatarSrc = computed(() => useMediaUrl(props.author.avatarMedia?.path));\nconst initials = computed(() => {\n  const name = props.author.name || '';\n  return name.trim().charAt(0).toUpperCase() || 'А';\n});\n\nconst subscribed = ref(false);\nconst loading = ref(false);\n\nasync function loadSubscription() {\n  if (!isAuthenticated.value || props.hideSubscribe) return;\n  try {\n    const res = await getAuthorSubscription(props.author.slug);\n    subscribed.value = (res as any).subscribed || false;\n  } catch {\n    subscribed.value = false;\n  }\n}\n\nasync function toggleSubscribe() {\n  if (!isAuthenticated.value) {\n    navigateTo(`/account?redirect=${encodeURIComponent(route.fullPath)}`);\n    return;\n  }\n  loading.value = true;\n  try {\n    if (subscribed.value) {\n      await unsubscribeFromAuthor(props.author.slug);\n      subscribed.value = false;\n      emit('change', false);\n    } else {\n      await subscribeToAuthor(props.author.slug);\n      subscribed.value = true;\n      emit('change', true);\n    }\n  } catch (err: any) {\n    // silently ignore\n  } finally {\n    loading.value = false;\n  }\n}\n\nonMounted(() => {\n  loadSubscription();\n});\n</script>\n\n<template>\n  <div class=\"flex items-center gap-3\">\n    <NuxtLink :to=\"authorLink\" class=\"shrink-0\">\n      <div v-if=\"avatarSrc\" class=\"h-10 w-10 overflow-hidden rounded-full\">\n        <NuxtImg\n          :src=\"avatarSrc\"\n          :alt=\"author.name\"\n          class=\"h-full w-full object-cover\"\n        />\n      </div>\n      <div\n        v-else\n        class=\"flex h-10 w-10 items-center justify-center rounded-full bg-green-600 text-sm font-bold uppercase text-white\"\n      >\n        {{ initials }}\n      </div>\n    </NuxtLink>\n    <div class=\"flex flex-wrap items-center gap-x-2 gap-y-1 text-sm\">\n      <span class=\"text-foreground/60\">Автор:</span>\n      <NuxtLink :to=\"authorLink\" class=\"font-medium text-foreground hover:text-accent\">\n        {{ author.name }}\n      </NuxtLink>\n      <button\n        v-if=\"!hideSubscribe\"\n        type=\"button\"\n        :disabled=\"loading\"\n        class=\"text-sm text-accent transition hover:text-accent/80 disabled:opacity-60\"\n        @click=\"toggleSubscribe\"\n      >\n        {{ subscribed ? 'Вы подписаны' : 'Подписаться' }}\n      </button>\n    </div>\n  </div>\n</template>\n"],"version":3}