{"file":"_id_-Bh0w3gVS.js","mappings":";;;;;;;;;;;;;;;;;;;;AAsBc,aAAA;AACoB,YAAA;AACM,WAAA;AAExC,UAAM,UAAU,IAAsB,IAAI;AAC1C,UAAM,YAAY,IAAgB,EAAE;AACpC,UAAM,UAAU,IAAI,KAAK;AACzB,UAAM,QAAQ,IAAI,EAAE;AAEpB,UAAM,aAAqC;AAAA,MACzC,QAAQ;AAAA,MACR,QAAQ;AAAA,MACR,QAAQ;AAAA,MACR,OAAO;AAAA,IAAA;AAGT,UAAM,aAAqC;AAAA,MACzC,SAAS;AAAA,MACT,MAAM;AAAA,MACN,OAAO;AAAA,MACP,SAAS;AAAA,IAAA;AAGX,UAAM,eAAuC;AAAA,MAC3C,OAAO;AAAA,MACP,WAAW;AAAA,MACX,WAAW;AAAA,MACX,UAAU;AAAA,IAAA;AAGZ,UAAM,eAAuC;AAAA,MAC3C,OAAO;AAAA,MACP,WAAW;AAAA,MACX,WAAW;AAAA,MACX,UAAU;AAAA,IAAA;AAqBZ,aAAS,WAAW,MAAsB;AACxC,UAAI,CAAC,KAAM,QAAO;AAClB,aAAO,IAAI,KAAK,IAAI,EAAE,mBAAmB,OAAO;AAAA,IAClD;;;AAYO,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,iCAA6B,MAAA,CAAA,CAAA,wOAAA;;QAM5B,IAAG;AAAA,QAAiB,OAAM;AAAA,MAAA;yBAApC,CAA4G,GAAAC,QAAAC,UAAA,aAAA;;;;;8BAAlC,yBAAuB;AAAA,YAAA;AAAA;;;;UAExFC,MAAA,OAAA,GAAO;;;;;UACPA,MAAA,KAAA,GAAK;qEAAuCA,MAAA,KAAA,CAAK,CAAA,MAAA;AAAA;;;UAE/CA,MAAA,OAAA,GAAO;sLAGwBA,MAAA,OAAA,EAAQ,eAAeA,MAAA,OAAA,EAAQ,YAAYA,MAAA,OAAA,EAAQ,KAAK,iGAInFC,eAAAD,MAAA,OAAA,EAAQ,KAAK,yEAIbC,eAAAD,MAAA,OAAA,EAAQ,YAAQ,GAAA,oFAIhBC,eAAAD,MAAA,OAAA,EAAQ,eAAW,GAAA,wEAInBC,eAAA,WAAWD,MAAA,OAAA,EAAQ,IAAI,KAAKA,MAAA,OAAA,EAAQ,IAAI,yFAIxC,WAAWA,MAAA,OAAA,EAAQ,SAAS,CAAA;AAQ7B,YAAA,CAAAA,MAAA,OAAA,EAAQ,UAAQ;;QACT,WAAA,CAAAA,MAAA,SAAA,EAAU,QAAM;;;;AAaXE,wBAAAF,MAAA,SAAA,IAAL,MAAC;uLAGqC,aAAa,EAAE,MAAM,KAAA,eAAA,sBAAA,CAAA,cAC7DC,eAAA,aAAa,EAAE,MAAM,KAAK,EAAE,MAAM,kEAGYA,eAAA,WAAW,EAAE,IAAI,KAAK,EAAE,IAAI;;cAEpE,IAAE,IAAM,EAAE,kCAAkC,EAAE,SAAI,SAAA,SAAuB,EAAE,SAAI,UAAA,WAAA,SAAA,IAAuC,EAAE,IAAI;AAAA,cAAI,OAAM;AAAA,cAAwC,QAAO;AAAA,YAAA;+BAAhM,CAEW,GAAAH,QAAAC,UAAA,aAAA;;AADND,yBAAA,GAAAG,eAAA,EAAE,KAAK,CAAA,EAAA;AAAA;;oBAAPE,gBAAAC,gBAAA,EAAE,KAAK,GAAA,CAAA;AAAA,kBAAA;AAAA;;;;4EAGuCH,eAAA,EAAE,cAAU,CAAA,0EACZ,WAAW,EAAE,SAAS,CAAA;;;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_push","_parent","_unref","_ssrInterpolate","_ssrRenderList","_createTextVNode","_toDisplayString"],"sources":["../../../../../../../pages/account/admin/users/[id].vue"],"sourcesContent":["<script setup lang=\"ts\">\ninterface AdminUser {\n  id: string;\n  email: string;\n  username: string | null;\n  displayName: string | null;\n  role: string;\n  createdAt: string;\n  authorId: string | null;\n}\n\ninterface Material {\n  id: string;\n  type: string;\n  title: string;\n  slug: string;\n  status: string;\n  updatedAt: string;\n  publishedAt?: string | null;\n  viewsTotal: number;\n}\n\nconst route = useRoute();\nconst { user, isAuthenticated } = useAuth();\nconst { getUser, getEditorMaterials } = useApi();\n\nconst profile = ref<AdminUser | null>(null);\nconst materials = ref<Material[]>([]);\nconst loading = ref(false);\nconst error = ref('');\n\nconst roleLabels: Record<string, string> = {\n  member: 'Читатель',\n  author: 'Автор',\n  editor: 'Редактор',\n  admin: 'Админ',\n};\n\nconst typeLabels: Record<string, string> = {\n  article: 'Статья',\n  news: 'Новость',\n  video: 'Видео',\n  gallery: 'Галерея',\n};\n\nconst statusLabels: Record<string, string> = {\n  draft: 'Черновик',\n  in_review: 'На проверке',\n  published: 'Опубликовано',\n  rejected: 'Отклонено',\n};\n\nconst statusColors: Record<string, string> = {\n  draft: 'bg-orange-500',\n  in_review: 'bg-yellow-500',\n  published: 'bg-accent',\n  rejected: 'bg-red-600',\n};\n\nasync function fetchData() {\n  loading.value = true;\n  error.value = '';\n  try {\n    profile.value = await getUser(route.params.id as string) as AdminUser;\n    if (profile.value?.authorId) {\n      const res: any = await getEditorMaterials({ authorId: profile.value.authorId });\n      materials.value = Array.isArray(res?.items) ? res.items : [];\n    } else {\n      materials.value = [];\n    }\n  } catch (err: any) {\n    error.value = err?.data?.message || err?.message || 'Ошибка загрузки данных';\n  } finally {\n    loading.value = false;\n  }\n}\n\nfunction formatDate(date?: string | null) {\n  if (!date) return '—';\n  return new Date(date).toLocaleDateString('ru-RU');\n}\n\nonMounted(() => {\n  if (!isAuthenticated.value || user.value?.role !== 'admin') {\n    navigateTo('/account');\n    return;\n  }\n  fetchData();\n});\n</script>\n\n<template>\n  <div class=\"mx-auto max-w-6xl px-4 py-8\">\n    <div class=\"mb-6 border-b border-foreground/10 pb-4\">\n      <p class=\"text-xs font-medium uppercase tracking-wider text-foreground/50\">Администрирование</p>\n      <h1 class=\"mt-2 font-heading text-2xl font-bold\">Профиль пользователя</h1>\n    </div>\n\n    <NuxtLink to=\"/account/admin\" class=\"text-sm text-accent hover:underline\">← Назад к пользователям</NuxtLink>\n\n    <p v-if=\"loading\" class=\"mt-6 text-sm text-foreground/60\">Загрузка...</p>\n    <p v-if=\"error\" class=\"mt-6 text-sm text-red-600\">{{ error }}</p>\n\n    <div v-if=\"profile\" class=\"mt-6 grid gap-6 lg:grid-cols-[320px_1fr]\">\n      <!-- User card -->\n      <div class=\"border border-foreground/10 bg-foreground/5 p-5\">\n        <h2 class=\"mb-4 text-lg font-bold\">{{ profile.displayName || profile.username || profile.email }}</h2>\n        <dl class=\"space-y-3 text-sm\">\n          <div>\n            <dt class=\"text-xs text-foreground/60\">Email</dt>\n            <dd>{{ profile.email }}</dd>\n          </div>\n          <div>\n            <dt class=\"text-xs text-foreground/60\">Логин</dt>\n            <dd>{{ profile.username || '—' }}</dd>\n          </div>\n          <div>\n            <dt class=\"text-xs text-foreground/60\">Отображаемое имя</dt>\n            <dd>{{ profile.displayName || '—' }}</dd>\n          </div>\n          <div>\n            <dt class=\"text-xs text-foreground/60\">Роль</dt>\n            <dd>{{ roleLabels[profile.role] || profile.role }}</dd>\n          </div>\n          <div>\n            <dt class=\"text-xs text-foreground/60\">Создан</dt>\n            <dd>{{ formatDate(profile.createdAt) }}</dd>\n          </div>\n        </dl>\n      </div>\n\n      <!-- Materials -->\n      <div>\n        <h3 class=\"mb-4 text-lg font-bold\">Записи пользователя</h3>\n        <p v-if=\"!profile.authorId\" class=\"text-sm text-foreground/60\">У пользователя ещё нет автора, записей нет.</p>\n        <div v-else-if=\"!materials.length\" class=\"text-sm text-foreground/60\">Нет записей</div>\n        <div v-else class=\"overflow-x-auto\">\n          <table class=\"w-full border-collapse border border-foreground/10 text-sm\">\n            <thead class=\"bg-foreground/10\">\n              <tr>\n                <th class=\"border border-foreground/10 px-3 py-2 text-left\">Статус</th>\n                <th class=\"border border-foreground/10 px-3 py-2 text-left\">Тип</th>\n                <th class=\"border border-foreground/10 px-3 py-2 text-left\">Заголовок</th>\n                <th class=\"border border-foreground/10 px-3 py-2 text-left\">Просмотры</th>\n                <th class=\"border border-foreground/10 px-3 py-2 text-left\">Обновлено</th>\n              </tr>\n            </thead>\n            <tbody>\n              <tr v-for=\"m in materials\" :key=\"m.id\" class=\"bg-foreground/5\">\n                <td class=\"border border-foreground/10 px-3 py-2\">\n                  <span class=\"inline-flex items-center gap-1.5 text-xs\">\n                    <span class=\"h-2 w-2 rounded-full\" :class=\"statusColors[m.status] || 'bg-gray-400'\" />\n                    {{ statusLabels[m.status] || m.status }}\n                  </span>\n                </td>\n                <td class=\"border border-foreground/10 px-3 py-2\">{{ typeLabels[m.type] || m.type }}</td>\n                <td class=\"border border-foreground/10 px-3 py-2\">\n                  <NuxtLink :to=\"`/${m.type === 'article' ? 'articles' : m.type === 'news' ? 'news' : m.type === 'video' ? 'videos' : 'gallery'}/${m.slug}`\" class=\"hover:text-foreground hover:underline\" target=\"_blank\">\n                    {{ m.title }}\n                  </NuxtLink>\n                </td>\n                <td class=\"border border-foreground/10 px-3 py-2\">{{ m.viewsTotal || 0 }}</td>\n                <td class=\"border border-foreground/10 px-3 py-2\">{{ formatDate(m.updatedAt) }}</td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n"],"version":3}