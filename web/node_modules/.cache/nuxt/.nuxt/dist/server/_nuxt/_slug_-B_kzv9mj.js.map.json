{"file":"_slug_-B_kzv9mj.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;AAGA,UAAM,QAAQ,SAAA;AACd,UAAM,OAAO,MAAM,OAAO;AAC1B,UAAM,EAAE,WAAW,iBAAA,IAAqB,OAAA;AAExC,UAAM,CAAC,EAAE,MAAM,OAAA,GAAU,EAAE,MAAM,QAAA,CAAS,KAAI,CAAA,QAAA,SAAA,IAAAA,iBAAA,MAAM,QAAQ,IAAI;AAAA,MAC9D;AAAA,QAAa,UAAU,IAAI;AAAA,QAAI,MAC7B,UAAU,IAAI,EAAE,MAAM,MAAM,IAAI;AAAA,MAAA;AAAA,MAElC;AAAA,QAAa,kBAAkB,IAAI;AAAA,QAAI,MACrC,iBAAiB,IAAI,EAAE,MAAM,OAAO,EAAE,OAAO,CAAA,IAAK;AAAA,MAAA;AAAA,IACpD,CACD,CAAA;AAED,QAAI,CAAC,OAAO,OAAO;AACjB,YAAM,YAAY,EAAE,YAAY,KAAK,eAAe,mBAAmB;AAAA,IACzE;AAEA,UAAM,UAAU,SAAS,MAAM,OAAO,KAA6B;AACnE,UAAM,QAAQ,SAAS,MAAO,QAAQ,OAAO,SAAS,EAAoB;AAC1E,UAAM,YAAY,SAAS,MAAM,YAAY,QAAQ,OAAO,aAAa,IAAI,CAAC;AAC9E,UAAM,WAAW,SAAS,MAAM;AAC9B,YAAM,OAAO,QAAQ,OAAO,QAAQ;AACpC,aAAO,KAAK,OAAO,OAAO,CAAC,EAAE,iBAAiB;AAAA,IAChD,CAAC;AAED,eAAW;AAAA,MACT,OAAO,GAAG,QAAQ,OAAO,QAAQ,IAAI;AAAA,MACrC,aAAa,QAAQ,OAAO,OAAO,oBAAoB,QAAQ,OAAO,QAAQ,IAAI;AAAA,IAAA,CACnF;;;;;AAIM,YAAA,OAAAC,eAAAC,WAAA,EAAA,OAAM,iCAA6B,MAAA,CAAA,CAAA,6GAAA;;QAG1B,IAAG;AAAA,QAAI,OAAM;AAAA,MAAA;yBAAvB,CAAiE,GAAAC,QAAAC,UAAA,aAAA;;;;;8BAAlB,SAAO;AAAA,YAAA;AAAA;;;;;UAQzCC,MAAA,SAAA,GAAS;;;UAEf,KAAKA,MAAA,SAAA;AAAA,UACL,KAAKA,MAAA,OAAA,GAAS,QAAI;AAAA,UACnB,OAAM;AAAA,QAAA;;;0JAOLA,MAAA,QAAA,CAAQ,CAAA,QAAA;AAAA;AAMR,YAAA,2GAAAC,eAAAD,MAAA,OAAA,GAAS,IAAI,CAAA,OAAA;AAET,UAAAA,MAAA,OAAA,GAAS,UAAQ;AACrB,cAAA,8CAAAC,eAAAD,MAAA,OAAA,EAAQ,QAAQ,CAAA,MAAA;AAAA;;;AAEZ,UAAAA,MAAA,OAAA,GAAS,KAAG;AAChB,cAAA,0EAAAC,eAAAD,MAAA,OAAA,EAAQ,GAAG,CAAA,MAAA;AAAA;;;;AAQN,UAAA,CAAAA,MAAA,KAAA,EAAM,QAAM;;;;AAKLE,sBAAAF,MAAA,KAAA,IAAR,SAAI;;YACV,KAAK,KAAK;AAAA,YACV;AAAA,YACD,gBAAa;AAAA,YACb,SAAQ;AAAA,YACR,OAAM;AAAA,UAAA;;;;;;;;;;;;;;","names":["_withAsyncContext","_ssrRenderAttrs","_mergeProps","_push","_parent","_unref","_ssrInterpolate","_ssrRenderList"],"sources":["../../../../../../../pages/author/[slug].vue"],"sourcesContent":["<script setup lang=\"ts\">\nimport type { AuthorProfile, ContentItem } from '~/types/content';\n\nconst route = useRoute();\nconst slug = route.params.slug as string;\nconst { getAuthor, getAuthorContent } = useApi();\n\nconst [{ data: author }, { data: content }] = await Promise.all([\n  useAsyncData(`author-${slug}`, () =>\n    getAuthor(slug).catch(() => null),\n  ),\n  useAsyncData(`author-content-${slug}`, () =>\n    getAuthorContent(slug).catch(() => ({ items: [] })),\n  ),\n]);\n\nif (!author.value) {\n  throw createError({ statusCode: 404, statusMessage: 'Автор не найден' });\n}\n\nconst profile = computed(() => author.value as AuthorProfile | null);\nconst items = computed(() => (content.value?.items || []) as ContentItem[]);\nconst avatarSrc = computed(() => useMediaUrl(profile.value?.avatarMedia?.path));\nconst initials = computed(() => {\n  const name = profile.value?.name || '';\n  return name.trim().charAt(0).toUpperCase() || 'А';\n});\n\nuseSeoMeta({\n  title: `${profile.value?.name || slug} — Автор`,\n  description: profile.value?.bio || `Материалы автора ${profile.value?.name || slug}`,\n});\n</script>\n\n<template>\n  <div class=\"mx-auto max-w-7xl px-4 py-8\">\n    <!-- Breadcrumbs -->\n    <nav class=\"mb-4 flex items-center gap-2 text-xs font-medium uppercase tracking-wider text-foreground/50\">\n      <NuxtLink to=\"/\" class=\"hover:text-foreground\">Главная</NuxtLink>\n      <span>/</span>\n      <span>Автор</span>\n    </nav>\n\n    <!-- Author header -->\n    <div class=\"grid gap-6 border-b border-foreground/10 pb-8 md:grid-cols-[160px_1fr]\">\n      <div class=\"shrink-0\">\n        <div v-if=\"avatarSrc\" class=\"h-40 w-40 overflow-hidden rounded-full\">\n          <NuxtImg\n            :src=\"avatarSrc\"\n            :alt=\"profile?.name || ''\"\n            class=\"h-full w-full object-cover\"\n          />\n        </div>\n        <div\n          v-else\n          class=\"flex h-40 w-40 items-center justify-center rounded-full bg-green-600 text-4xl font-bold uppercase text-white\"\n        >\n          {{ initials }}\n        </div>\n      </div>\n\n      <div class=\"flex flex-col justify-center\">\n        <h1 class=\"font-heading text-3xl font-bold md:text-4xl\">\n          {{ profile?.name }}\n        </h1>\n        <p v-if=\"profile?.position\" class=\"mt-1 text-sm text-foreground/60\">\n          {{ profile.position }}\n        </p>\n        <p v-if=\"profile?.bio\" class=\"mt-4 max-w-3xl text-base leading-relaxed text-foreground/80\">\n          {{ profile.bio }}\n        </p>\n      </div>\n    </div>\n\n    <!-- Publications -->\n    <div class=\"mt-10\">\n      <h2 class=\"mb-6 font-heading text-2xl font-bold\">Все публикации автора</h2>\n      <div v-if=\"!items.length\" class=\"text-sm text-foreground/60\">\n        У автора пока нет публикаций.\n      </div>\n      <div v-else class=\"grid gap-6 md:grid-cols-2 lg:grid-cols-3\">\n        <ArticleCard\n          v-for=\"item in items\"\n          :key=\"item.id\"\n          :item=\"item\"\n          image-aspect=\"video\"\n          variant=\"compact\"\n          class=\"h-[320px]\"\n        />\n      </div>\n    </div>\n  </div>\n</template>\n"],"version":3}