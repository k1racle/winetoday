{"file":"liked-tIdsg6-t.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;AAG4B,YAAA;AACL,WAAA;AAEvB,UAAM,QAAQ,IAAmB,EAAE;AACnC,UAAM,UAAU,IAAI,KAAK;AACzB,UAAM,QAAQ,IAAI,EAAE;;;;AAwBb,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,iCAA6B,MAAA,CAAA,CAAA,uEAAA;AAEzB,YAAAC,mBAAA,wBAAA,EAAA,OAAM,UAAM,MAAA,OAAA,CAAA;;UAIhBC,MAAA,OAAA,GAAO;;;;;UACPA,MAAA,KAAA,GAAK;gEAAkCA,MAAA,KAAA,CAAK,CAAA,MAAA;AAAA;;;WAEzCA,MAAA,OAAA,KAAO,CAAKA,MAAA,KAAA,EAAM,QAAM;;;;AAMjBC,sBAAAD,MAAA,KAAA,IAAR,SAAI;;YACV,KAAK,KAAK;AAAA,YACV;AAAA,YACD,gBAAa;AAAA,YACb,SAAQ;AAAA,YACR,OAAM;AAAA,UAAA;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderComponent","_unref","_ssrRenderList"],"sources":["../../../../../../../pages/account/liked.vue"],"sourcesContent":["<script setup lang=\"ts\">\nimport type { ContentItem } from '~/types/content';\n\nconst { isAuthenticated } = useAuth();\nconst { getMyLikes } = useApi();\n\nconst items = ref<ContentItem[]>([]);\nconst loading = ref(false);\nconst error = ref('');\n\nasync function load() {\n  loading.value = true;\n  error.value = '';\n  try {\n    items.value = (await getMyLikes()) as ContentItem[];\n  } catch (err: any) {\n    error.value = err?.data?.message || err?.message || 'Ошибка загрузки';\n  } finally {\n    loading.value = false;\n  }\n}\n\nonMounted(() => {\n  if (!isAuthenticated.value) {\n    navigateTo('/');\n    return;\n  }\n  load();\n});\n</script>\n\n<template>\n  <div class=\"mx-auto max-w-7xl px-4 py-8\">\n    <h1 class=\"mb-2 font-heading text-2xl font-bold\">Личный кабинет</h1>\n    <AccountTabs class=\"mb-6\" />\n\n    <h2 class=\"mb-4 font-heading text-xl font-bold\">Понравившиеся записи</h2>\n\n    <p v-if=\"loading\" class=\"text-sm text-foreground/60\">Загрузка...</p>\n    <p v-if=\"error\" class=\"text-sm text-red-500\">{{ error }}</p>\n\n    <div v-if=\"!loading && !items.length\" class=\"text-sm text-foreground/60\">\n      У вас пока нет понравившихся записей.\n    </div>\n\n    <div v-else class=\"grid gap-6 md:grid-cols-2 lg:grid-cols-3\">\n      <ArticleCard\n        v-for=\"item in items\"\n        :key=\"item.id\"\n        :item=\"item\"\n        image-aspect=\"video\"\n        variant=\"compact\"\n        class=\"h-[320px]\"\n      />\n    </div>\n  </div>\n</template>\n"],"version":3}